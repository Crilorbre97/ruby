<h2><%= t(".title") %> </h2>

<% @categories.each do |category| %>
    <ul>
        <li>
            <%= category.label.capitalize %>
            <%= link_to t(".delete"), category_path(category.id), data: { turbo_prefetch: false, turbo_method: :delete, turbo_confirm: t("common.confirm") } if Current.user.present? && policy(category).destroy? %>
        </li>
    </ul>
<% end %>

<%= link_to t(".new"), new_category_path, data: { turbo_prefetch: false } if Current.user.present? && policy(Category.new).new? %>