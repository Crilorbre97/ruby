<h1>Listado de productos</h1>

<%= link_to "Categorias", categories_path, data: { turbo_prefetch: false } %>

<% @products.each do |product| %>
    <div>
        <%= product.title %>

        <%= link_to 'Ver', product_path(product.id), data: { turbo_prefetch: false } %>
        <%= link_to 'Editar', edit_product_path(product.id), data: { turbo_prefetch: false } %>
    </div>
<% end %>

<%= link_to 'Añadir producto', new_product_path, data: { turbo_prefetch: false }  %>
