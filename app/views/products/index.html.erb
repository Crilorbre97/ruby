<h1><%= t('.title') %></h1>

<%= link_to t('.categories'), categories_path, data: { turbo_prefetch: false } %>

<% @products.each do |product| %>
    <div>
        <%= product.title %>

        <%= link_to t('.show'), product_path(product.id), data: { turbo_prefetch: false } %>
        <%= link_to t('.edit'), edit_product_path(product.id), data: { turbo_prefetch: false } %>
    </div>
<% end %>

<%= link_to t('.add'), new_product_path, data: { turbo_prefetch: false }  %>
