<tr>
    <td><%= product.title %></td>
    <td><%= product.price %></td>
    <td><%= product.created_at&.strftime("%d-%m-%Y %H:%M") %></td>
    <td>
        <%= link_to t('.show'), product_path(product.id), data: { turbo: false, turbo_prefetch: false } %>
        <%= link_to t('.edit'), edit_product_path(product.id), data: { turbo: false, turbo_prefetch: false } if Current.user.present? && policy(product).update? %>
    </td>
</tr>
